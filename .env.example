# ─────────────────────────────────────────────────────────────────────────────
#  Breathometer 6.0 — Environment Variables Reference
#  Copy this file to .env.local (dev) or configure these in Render / CI.
#  Never commit real secret values.
# ─────────────────────────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════════
#  FRONTEND (Vite — must be prefixed VITE_)
# ══════════════════════════════════════════════════════════════

# Backend Render service URL
VITE_API_BASE_URL=https://breathometer6-0.onrender.com

# Sentry (initialised only after user cookie consent — see main.jsx)
VITE_SENTRY_DSN=https://REPLACE_ME@o0.ingest.sentry.io/REPLACE_ME

# Firebase VAPID public key for Web Push / FCM
VITE_FIREBASE_VAPID_KEY=REPLACE_ME

# WAQI air quality tile token (waqi.info dashboard → free API key)
VITE_WAQI_TILE_TOKEN=REPLACE_ME

# ══════════════════════════════════════════════════════════════
#  BACKEND (FastAPI on Render — set in Render Dashboard → Environment)
# ══════════════════════════════════════════════════════════════

# ── Required ────────────────────────────────────────────────
SUPABASE_URL=https://REPLACE_ME.supabase.co
SUPABASE_KEY=REPLACE_ME                    # anon/public key
GEMINI_API_KEY=REPLACE_ME
GROQ_API_KEY=REPLACE_ME
AQICN_API_KEY=REPLACE_ME
OPENWEATHER_API_KEY=REPLACE_ME

# ── Optional (degraded mode if absent) ──────────────────────
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME       # needed for admin operations
GOOGLE_MAPS_API_KEY=REPLACE_ME            # doctor map lookups
BREVO_API_KEY=REPLACE_ME                  # transactional email
SENTRY_DSN=REPLACE_ME                     # backend error tracking
FCM_SERVER_KEY=REPLACE_ME                 # Firebase push to backend
