  "components": {
    "schemas": {
      "BreathTestRequest": {
        "properties": {
          "lung_capacity": {
            "type": "number",
            "title": "Lung Capacity"
          },
          "breath_duration": {
            "type": "number",
            "title": "Breath Duration"
          },
          "breath_strength": {
            "type": "number",
            "title": "Breath Strength"
          },
          "test_accuracy": {
            "type": "number",
            "title": "Test Accuracy"
          },
          "peak_airflow": {
            "type": "number",
            "title": "Peak Airflow",
            "default": 0.0
          },
          "signal_stability": {
            "type": "number",
            "title": "Signal Stability",
            "default": 0.0
          },
          "is_valid": {
            "type": "boolean",
            "title": "Is Valid",
            "default": true
          },
          "background_noise_detected": {
            "type": "boolean",
            "title": "Background Noise Detected",
            "default": false
          },
          "cough_detected": {
            "type": "boolean",
            "title": "Cough Detected",
            "default": false
          },
          "raw_attempts": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Raw Attempts",
            "default": []
          }
        },
        "type": "object",
        "required": [
          "lung_capacity",
          "breath_duration",
          "breath_strength",
          "test_accuracy"
        ],
        "title": "BreathTestRequest"
      },
      "ChatMessage": {
        "properties": {
          "message": {
            "type": "string",
            "title": "Message"
          },
          "user_context": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "User Context",
            "default": {}
          }
        },
        "type": "object",
        "required": [
          "message"
        ],
        "title": "ChatMessage"
      },
      "ChatRequest": {
        "properties": {
          "message": {
            "type": "string",
            "title": "Message"
          },
          "response": {
            "type": "string",
            "title": "Response"
          }
        },
        "type": "object",
        "required": [
          "message",
          "response"
        ],
        "title": "ChatRequest"
      },
      "ChatResponse": {
        "properties": {
          "reply": {
            "type": "string",
            "title": "Reply"
          }
        },
        "type": "object",
        "required": [
          "reply"
        ],
        "title": "ChatResponse"
      },
      "EnvironmentRequest": {
        "properties": {
          "pm25": {
            "type": "number",
            "title": "Pm25"
          },
          "pm10": {
            "type": "number",
            "title": "Pm10"
          },
          "aqi": {
            "type": "number",
            "title": "Aqi"
          },
          "location": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Location"
          }
        },
        "type": "object",
        "required": [
          "pm25",
          "pm10",
          "aqi"
        ],
        "title": "EnvironmentRequest"
      },
      "EnvironmentalData": {
        "properties": {
